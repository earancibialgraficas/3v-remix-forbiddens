+}
+
+Write-Host "Pusheando branch a origin..."
+git push -u origin $branch
+if ($LASTEXITCODE -ne 0) { Fail 'git push falló. Verifica permisos y conexión remota.' }
+
+if (Get-Command gh -ErrorAction SilentlyContinue) {
